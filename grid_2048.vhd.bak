library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;

entity grid_2048 is
  port(
    pixel_row    : in std_logic_vector(10 downto 0);
    pixel_column : in std_logic_vector(10 downto 0);
    Red          : out std_logic_vector(7 downto 0);
    Green        : out std_logic_vector(7 downto 0);
    Blue         : out std_logic_vector(7 downto 0)
  );
end grid_2048;

architecture behavior of grid_2048 is

  constant BOARD_X    : integer := 252;
  constant BOARD_Y    : integer := 124;
  constant CELL_SIZE  : integer := 120;
  constant GAP        : integer := 10;
  constant BOARD_SIZE : integer := 4 * CELL_SIZE + 3 * GAP;  -- 510

begin

  process(pixel_row, pixel_column)
    variable x, y : integer;
    variable row_idx, col_idx : integer;
    variable cell_x, cell_y : integer;
    variable tile_val : integer;
  begin
    x := to_integer(unsigned(pixel_column));
    y := to_integer(unsigned(pixel_row));

    -- screen background
    Red   <= x"FA";
    Green <= x"F8";
    Blue  <= x"EF";

    if (x >= BOARD_X) and (x < BOARD_X + BOARD_SIZE) and
       (y >= BOARD_Y) and (y < BOARD_Y + BOARD_SIZE) then

      -- board background / border area
      Red   <= x"BB";
      Green <= x"AD";
      Blue  <= x"A0";

      col_idx := (x - BOARD_X) / (CELL_SIZE + GAP);
      row_idx := (y - BOARD_Y) / (CELL_SIZE + GAP);

      cell_x := (x - BOARD_X) mod (CELL_SIZE + GAP);
      cell_y := (y - BOARD_Y) mod (CELL_SIZE + GAP);

      -- inside one of the 16 squares
      if (col_idx >= 0 and col_idx <= 3 and row_idx >= 0 and row_idx <= 3) then
        if (cell_x < CELL_SIZE) and (cell_y < CELL_SIZE) then

          -- hardcoded sample board
          -- value meanings:
          -- 0 empty
          -- 1 = 2
          -- 2 = 4
          -- 3 = 8
          -- 4 = 16
          -- etc.

          if    row_idx = 0 and col_idx = 0 then tile_val := 1; -- 2
          elsif row_idx = 0 and col_idx = 1 then tile_val := 2; -- 4
          elsif row_idx = 0 and col_idx = 2 then tile_val := 3; -- 8
          elsif row_idx = 0 and col_idx = 3 then tile_val := 4; -- 16

          elsif row_idx = 1 and col_idx = 0 then tile_val := 0;
          elsif row_idx = 1 and col_idx = 1 then tile_val := 1;
          elsif row_idx = 1 and col_idx = 2 then tile_val := 0;
          elsif row_idx = 1 and col_idx = 3 then tile_val := 2;

          elsif row_idx = 2 and col_idx = 0 then tile_val := 3;
          elsif row_idx = 2 and col_idx = 1 then tile_val := 0;
          elsif row_idx = 2 and col_idx = 2 then tile_val := 4;
          elsif row_idx = 2 and col_idx = 3 then tile_val := 0;

          elsif row_idx = 3 and col_idx = 0 then tile_val := 5; -- 32
          elsif row_idx = 3 and col_idx = 1 then tile_val := 6; -- 64
          elsif row_idx = 3 and col_idx = 2 then tile_val := 7; -- 128
          else                                tile_val := 8; -- 256
          end if;

          case tile_val is
            when 0  => Red <= x"CD"; Green <= x"C1"; Blue <= x"B4"; -- empty
            when 1  => Red <= x"EE"; Green <= x"E4"; Blue <= x"DA"; -- 2
            when 2  => Red <= x"ED"; Green <= x"E0"; Blue <= x"C8"; -- 4
            when 3  => Red <= x"F2"; Green <= x"B1"; Blue <= x"79"; -- 8
            when 4  => Red <= x"F5"; Green <= x"95"; Blue <= x"63"; -- 16
            when 5  => Red <= x"F6"; Green <= x"7C"; Blue <= x"5F"; -- 32
            when 6  => Red <= x"F6"; Green <= x"5E"; Blue <= x"3B"; -- 64
            when 7  => Red <= x"ED"; Green <= x"CF"; Blue <= x"72"; -- 128
            when 8  => Red <= x"ED"; Green <= x"CC"; Blue <= x"61"; -- 256
            when 9  => Red <= x"ED"; Green <= x"C8"; Blue <= x"50"; -- 512
            when 10 => Red <= x"ED"; Green <= x"C5"; Blue <= x"3F"; -- 1024
            when others =>
              Red <= x"ED"; Green <= x"C2"; Blue <= x"2E"; -- 2048+
          end case;

        end if;
      end if;
    end if;
  end process;

end behavior;